# 服务端口
PORT=3000

# WireGuard 配置文件目录
CONF_DIR=/app/conf

# 配置文件存储路径（配置通过Web界面管理）
CONFIG_FILE=/app/data/config.json

# Token文件存储路径
TOKEN_FILE=/app/data/tokens.json

# 路由器脚本目录（add-client.sh / delete-client.sh）；可挂载宿主机目录覆盖镜像内脚本
SCRIPT_DIR=/app/script

# add-client.sh：容器内无 wg 接口时必填，值为路由器上 wg show <接口> public-key 的输出
# WG_PUBLIC_KEY=

# 客户端 [Peer] Endpoint，例如 vpn.example.com:51820
# WG_SERVER=vpn.example.com:51820

# add/delete 脚本路径（容器默认 /app/script/peers.list、/app/conf，与挂载一致；路由器上请改成实际路径）
# PEERS_FILE=/app/script/peers.list
# CONF_DIR=/app/conf
# WG_INTERFACE=WG

# Web登录认证（默认：admin/admin123）
WEB_USERNAME=admin
WEB_PASSWORD=admin123
